APP_ENV=production
DATABASE_URL=postgresql+psycopg://site_selection:REPLACE_WITH_PASSWORD@127.0.0.1:5432/site_selection
# 后端使用高德 Web 服务 Key；不要填写前端 JavaScript API Key。
AMAP_WEB_SERVICE_KEY=
AMAP_MOCK=false
SCORING_CONFIG_PATH=app/scoring/default.yaml
ENABLE_DEBUG_ENDPOINTS=false
# M1 当前报告为规则评分报告，不调用大模型；不要在前端或日志中暴露 LLM/API Key。
