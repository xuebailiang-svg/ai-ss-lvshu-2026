POSTGRES_DB=site_selection
POSTGRES_USER=site_selection
POSTGRES_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql+psycopg://site_selection:change_this_strong_password@db:5432/site_selection
# 后端使用高德 Web 服务 Key；不要填写前端 JavaScript API Key。
AMAP_WEB_SERVICE_KEY=
AMAP_MOCK=false
ENABLE_DEBUG_ENDPOINTS=false
# 仅填写允许公开到浏览器的高德 JavaScript API 配置。
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY_JS_CODE=
APP_ENV=production
APP_BASE_URL=http://localhost
WEB_PORT=80
# M1 当前报告为规则评分报告，不调用大模型。
